{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm --prefix apps/mobile ci",
  "buildCommand": "npm --prefix apps/mobile run build",
  "outputDirectory": "apps/mobile/dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/"
    }
  ]
}
