# Diabetes Guardian environment variables
# Copy this file to .env and fill in your real credentials.
# Only expose EXPO_PUBLIC_* values to the mobile client.

# App environment
APP_ENV=development

# Supabase
# Public values can be used by Expo/mobile.
SUPABASE_URL=
SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase values.
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Optional backend base URL if you add Edge Functions or a FastAPI fallback.
EXPO_PUBLIC_API_BASE_URL=

# OpenAI
OPENAI_API_KEY=


# Gemini
GEMINI_API_KEY=

# Pinecone
PINECONE_API_KEY=
PINECONE_HOST=
PINECONE_INDEX=

# Nutrition provider routing
# Allowed values from the architecture docs: fatsecret | nutritionix
NUTRITION_PROVIDER=fatsecret

# Nutritionix
NUTRITIONIX_APP_ID=
NUTRITIONIX_APP_KEY=
NUTRITIONIX_BASE_URL=https://trackapi.nutritionix.com/v2

# FatSecret
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=
FATSECRET_OAUTH_URL=https://oauth.fatsecret.com/connect/token
FATSECRET_API_URL=https://platform.fatsecret.com/rest/server.api

# OpenFDA
# Optional, but useful if you want higher rate limits or per-project tracking.
OPENFDA_API_KEY=
OPENFDA_BASE_URL=https://api.fda.gov
