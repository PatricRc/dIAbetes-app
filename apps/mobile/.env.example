# Diabetes Guardian — Mobile App
# Copy this file to .env and fill in your real values.
# All EXPO_PUBLIC_ vars are bundled into the app at build time.

# Gemini (Google AI Studio → https://aistudio.google.com/app/apikey)
EXPO_PUBLIC_GEMINI_API_KEY=

# Pinecone (https://app.pinecone.io)
EXPO_PUBLIC_PINECONE_API_KEY=
EXPO_PUBLIC_PINECONE_INDEX_HOST=https://your-index-name.svc.environment.pinecone.io
EXPO_PUBLIC_PINECONE_INDEX_NAME=diabetes-guardian

# OpenAI (https://platform.openai.com/api-keys)
EXPO_PUBLIC_OPENAI_API_KEY=

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_PROJECT_REF=

# Demo patient credentials (Supabase Auth user for hackathon demo)
EXPO_PUBLIC_SUPABASE_DEMO_EMAIL=
EXPO_PUBLIC_SUPABASE_DEMO_PASSWORD=
